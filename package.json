{
  "name": "vps-finder",
  "version": "4.0.0",
  "description": "VPS Finder - автоматический поиск и сравнение VPS серверов по всему миру",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "update": "node scripts/auto-update.js",
    "update:providers": "node scripts/collect-providers.js",
    "update:prices": "node scripts/scrape-prices.js",
    "dev": "nodemon server.js",
    "security": "npm audit",
    "postinstall": "echo '✅ Установка завершена'"
  },
  "keywords": [
    "vps",
    "hosting",
    "cloud",
    "server",
    "search",
    "comparison"
  ],
  "author": "VPS Finder",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^1.6.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/vps-finder.git"
  }
}
