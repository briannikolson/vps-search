# VPS Finder - Пример конфигурации
# Скопируйте этот файл как .env и заполните своими значениями
# .env файл НЕ КОММИТЬТЕ в репозиторий!

# Пароль для доступа к веб-интерфейсу (обязательно!)
# Минимум 8 символов
ACCESS_PASSWORD=your-strong-password-here

# Порт для запуска (по умолчанию 3000)
PORT=3000

# Режим разработки (development/production)
NODE_ENV=production

# Секретный ключ для JWT (генерируется автоматически при установке)
JWT_SECRET=

# Настройки rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=300

# Интервал обновления данных в часах (по умолчанию 24)
UPDATE_INTERVAL_HOURS=24

# Разрешенные домены для CORS (через запятую)
ALLOWED_ORIGINS=http://localhost:3000
